{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eCode",
  "version": "0.1.0",
  "identifier": "com.ecode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "eCode",
        "width": 1440,
        "height": 920,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
